# ─── Database ───────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/loanlens?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USER=loanlens
DB_PASS=loanlens_pass

# ─── JWT (generate with: openssl rand -base64 48) ───────────────────────
JWT_SECRET=change-me-to-a-random-48-char-secret-value-minimum

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ─── Spring ─────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
PORT=8080

# ─── Monitoring ─────────────────────────────────────────────────────────
GRAFANA_PASS=admin

# ─── AWS (production only) ──────────────────────────────────────────────
# AWS_ACCOUNT_ID=123456789012
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
